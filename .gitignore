**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
**/build/
/coverage/
.agent/appdata/
.agent/gradle/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Test Output & Artifacts
*.log
*_test_output*.txt
test_results.txt
test_output.txt
test_ui_output*.txt

# Hive Databases
*.hive
*.lock

# Credentials
gen-lang-client-*.json
firebase-config.js

# Secrets and API Keys
secrets/
play_counts.hive
play_counts.lock
ratings.hive
ratings.lock
user_history.hive
user_history.lock

# Local Data Storage
/data/
AUDIT_REPORT.md

# gdar_web is web-only — prevent native platform dirs from regenerating
apps/gdar_web/android/
apps/gdar_web/ios/
apps/gdar_web/windows/
apps/gdar_web/macos/
apps/gdar_web/linux/


# Catch all build IDs across web, ios, and packages
**/.last_build_id

**/GeneratedPluginRegistrant.swift


# Ignore platform-specific generated files
**/GeneratedPluginRegistrant.swift
**/GeneratedPluginRegistrant.m


# First, ignore everything in the core package that is usually junk
packages/shakedown_core/.dart_tool/
packages/shakedown_core/build/

# Then, explicitly ensure the test directory is NOT ignored
!packages/shakedown_core/test/
!packages/shakedown_core/test/**


