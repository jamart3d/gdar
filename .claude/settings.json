{
  "permissions": {
    "allow": [
      "Bash(flutter test:*)",
      "Bash(dart analyze:*)",
      "Bash(./gradlew :app:compileDebugKotlin --info)",
      "Bash(./gradlew :app:compileReleaseKotlin)",
      "Bash(./gradlew :app:compileReleaseKotlin --stacktrace)",
      "Bash(./gradlew :app:processReleaseResources)",
      "Bash(flutter --version)",
      "Bash(flutter build:*)",
      "Bash(git checkout:*)",
      "Bash(grep -v \"^[+-]\\\\s*$\")",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(flutter analyze:*)",
      "Bash(flutter sdk-path:*)",
      "Bash(xargs dirname:*)",
      "mcp__dart__analyze_files",
      "mcp__dart__run_tests",
      "mcp__dart__dart_format",
      "Bash(flutter pub:*)",
      "Bash(dart fix:*)",
      "Bash(melos run:*)",
      "Bash(dart format:*)",
      "Bash(dart pub:*)",
      "Bash(dart run:*)",
      "Bash(grep:*)",
      "Bash(bash ~/.claude/statusline-command.sh)",
      "Bash(find packages/shakedown_core -name *steal* -o -name *screensaver*)",
      "Skill(update-config)",
      "Skill(update-config:*)"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "sequential-thinking"
  ],
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"systemMessage\": \"Claude finished.\"}'"
          }
        ]
      }
    ]
  }
}
